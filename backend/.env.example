# Database Configuration
# Local MongoDB: mongodb://localhost:27017/election_voting
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/election_voting
MONGODB_URI=mongodb://localhost:27017/election_voting

# JWT Secret Key - Change this in production!
# Generate secure key: openssl rand -base64 32
JWT_SECRET=mysecretkey123456789

# Server Port
PORT=5000

# Environment
NODE_ENV=development

# Frontend URL - Must match where frontend is running
FRONTEND_URL=http://localhost:5173